{
  "$meta": {
    "brand": "Narodowy Bank Polski (NBP)",
    "source": "https://nbp.pl/",
    "extractedAt": "2026-06-24"
  },
  "colors": {
    "brand": {
      "primary": "#152E52",
      "accent": "#BDAD7D",
